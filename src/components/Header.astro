---
import { SITE } from '../site.config.mjs';
import products from '../data/products.json';

// kategorije zgradimo iz produktov (unikatne, po abecedi)
const categories = [...new Map(
  products.map((p) => [p.categorySlug, { slug: p.categorySlug, name: p.category }])
).values()].sort((a, b) => a.name.localeCompare(b.name));
---

<header class="sticky top-0 z-30 border-b border-black/5 bg-cream/90 backdrop-blur">
  <div class="mx-auto flex max-w-content items-center justify-between gap-4 px-4 py-4">
    <a href="/" class="font-serif text-xl font-bold tracking-tight text-ink">
      {SITE.name}
    </a>
    <nav class="hidden items-center gap-6 text-sm font-medium text-muted md:flex">
      <a href="/" class="transition hover:text-ink">Home</a>
      {categories.map((c) => (
        <a href={`/${c.slug}`} class="transition hover:text-ink">{c.name}</a>
      ))}
      <a href="/blog" class="transition hover:text-ink">Blog</a>
      <a href="/about" class="transition hover:text-ink">About</a>
    </nav>
  </div>
  <!-- mobilna kategorijska vrstica -->
  <div class="flex gap-4 overflow-x-auto px-4 pb-3 text-sm text-muted md:hidden">
    {categories.map((c) => (
      <a href={`/${c.slug}`} class="whitespace-nowrap transition hover:text-ink">{c.name}</a>
    ))}
  </div>
</header>
