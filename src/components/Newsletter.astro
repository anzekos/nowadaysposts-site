---
// Newsletter prijava — POSTa na Cloudflare Pages funkcijo /subscribe,
// ki doda email v Brevo listo. API ključ NI v brskalniku (je v funkciji).
---

<section class="mx-auto max-w-content px-4 py-12">
  <div class="rounded-3xl bg-ink px-6 py-10 text-center shadow-lift sm:px-12 sm:py-14">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta">Free · a few times a week</p>
    <h2 class="mt-3 font-serif text-3xl font-bold text-white">Never miss the find everyone's pinning</h2>
    <p class="mx-auto mt-3 max-w-xl text-white/70">
      The prettiest trending home pieces, hand-picked and sent straight to your inbox —
      before they sell out. No spam, unsubscribe anytime.
    </p>
    <form id="newsletter-form" class="mx-auto mt-6 flex max-w-md flex-col gap-3 sm:flex-row" novalidate>
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input
        id="newsletter-email"
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder="you@email.com"
        class="w-full rounded-full border-0 px-5 py-3 text-ink placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-terracotta"
      />
      <button
        type="submit"
        class="shrink-0 rounded-full bg-terracotta px-7 py-3 text-sm font-semibold text-white transition hover:bg-white hover:text-ink disabled:opacity-60"
      >
        Subscribe
      </button>
    </form>
    <p id="newsletter-msg" class="mt-3 min-h-[1.25rem] text-sm text-white/80" role="status" aria-live="polite"></p>
  </div>
</section>

<script>
  const form = document.getElementById('newsletter-form');
  const msg = document.getElementById('newsletter-msg');
  if (form && msg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[name="email"]');
      const btn = form.querySelector('button');
      const email = (input?.value || '').trim();
      if (!email) return;
      btn.disabled = true;
      msg.textContent = 'Subscribing…';
      try {
        const r = await fetch('/subscribe', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await r.json().catch(() => ({}));
        if (r.ok && data.ok) {
          msg.textContent = "🎉 You're in! Get ready — your inbox is about to get a whole lot prettier. 🏡";
          form.reset();
        } else {
          msg.textContent = data.error || 'Something went wrong. Please try again.';
        }
      } catch {
        msg.textContent = 'Network error. Please try again.';
      } finally {
        btn.disabled = false;
      }
    });
  }
</script>
