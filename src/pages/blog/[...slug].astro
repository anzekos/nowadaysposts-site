---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import products from '../../data/products.json';
import { SITE } from '../../site.config.mjs';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const byAsin = new Map(products.map((p) => [p.asin, p]));
const items = (post.data.asins ?? []).map((a) => byAsin.get(a)).filter(Boolean);

const dateStr = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<Layout title={`${post.data.title} — ${SITE.name}`} description={post.data.description}>
  <article class="mx-auto max-w-3xl px-4 py-12">
    <nav class="mb-4 text-sm text-muted">
      <a href="/blog" class="hover:text-ink">Blog</a> <span class="px-1">/</span>
      <span class="text-ink">{dateStr}</span>
    </nav>
    <h1 class="font-serif text-4xl font-bold leading-tight text-ink">{post.data.title}</h1>
    <time class="mt-3 block text-sm text-muted">{dateStr}</time>

    <div class="prose prose-stone mt-8 max-w-none prose-headings:font-serif prose-a:text-terracotta">
      <Content />
    </div>

    {items.length > 0 && (
      <section class="mt-12">
        <h2 class="font-serif text-2xl font-bold text-ink">The finds</h2>
        <p class="mt-1 text-sm text-muted">{SITE.disclosureShort}</p>
        <div class="mt-6 grid gap-6 sm:grid-cols-2">
          {items.map((p) => <ProductCard product={p} />)}
        </div>
      </section>
    )}

    <div class="mt-12 border-t border-black/5 pt-6">
      <a href="/blog" class="text-sm font-semibold text-ink hover:text-terracotta">← Back to the blog</a>
    </div>
  </article>
</Layout>
