---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import Newsletter from '../components/Newsletter.astro';
import products from '../data/products.json';
import { SITE } from '../site.config.mjs';

// kategorije + števec + naslovna slika (najbolje ocenjen produkt kategorije)
const catMap = new Map();
for (const p of products) {
  const c = catMap.get(p.categorySlug) ?? {
    slug: p.categorySlug,
    name: p.category,
    count: 0,
    image: p.image,
    bestRating: -1,
  };
  c.count++;
  if ((p.rating ?? 0) > c.bestRating) {
    c.bestRating = p.rating ?? 0;
    c.image = p.image;
  }
  catMap.set(p.categorySlug, c);
}
const categories = [...catMap.values()].sort((a, b) => b.count - a.count);

// "Trending now" = najnovejših 12 (po addedAt)
const trending = [...products]
  .sort((a, b) => String(b.addedAt ?? '').localeCompare(String(a.addedAt ?? '')))
  .slice(0, 12);

// povprečna ocena za trust vrstico
const avgRating = (
  products.reduce((s, p) => s + (p.rating ?? 0), 0) / products.length
).toFixed(1);

// zadnji blog post (teaser)
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const latest = posts[0];
const fmt = (d) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-gradient-to-b from-cream to-beige/60">
    <div class="mx-auto max-w-content px-4 pb-14 pt-16 text-center sm:pb-16 sm:pt-20">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-terracotta">
        Handpicked home decor, daily
      </p>
      <h1 class="mx-auto max-w-3xl font-serif text-4xl font-bold leading-tight text-ink sm:text-5xl">
        The trending pieces that make a room look designed.
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-muted">
        Mirrors, florals, rugs and cozy finds we'd actually put in our own home —
        curated fresh every day from thousands of top-rated Amazon bestsellers.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="#trending"
          class="inline-flex w-full items-center justify-center rounded-full bg-terracotta px-7 py-3.5 text-sm font-semibold text-white shadow-soft transition hover:bg-terracotta-dark sm:w-auto"
        >
          Shop the trending edit ↓
        </a>
        <a
          href="#categories"
          class="inline-flex w-full items-center justify-center rounded-full border border-ink/15 bg-white/70 px-7 py-3.5 text-sm font-semibold text-ink transition hover:border-terracotta hover:text-terracotta sm:w-auto"
        >
          Browse by category
        </a>
      </div>
      <!-- trust vrstica -->
      <div class="mx-auto mt-8 flex max-w-xl flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-muted">
        <span class="inline-flex items-center gap-1.5">
          <span class="text-gold" aria-hidden="true">★</span> {avgRating} avg. rating
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-4 w-4 text-terracotta" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" /></svg>
          Only 4.5★+ picks
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-4 w-4 text-terracotta" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" /></svg>
          {products.length}+ curated finds
        </span>
      </div>
      <p class="mt-5 text-xs text-muted/80">{SITE.disclosureShort}</p>
    </div>
  </section>

  <!-- KATEGORIJE (vizualne kartice) -->
  <section id="categories" class="mx-auto max-w-content scroll-mt-20 px-4 py-14">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <h2 class="font-serif text-3xl font-bold text-ink">Shop by category</h2>
        <p class="mt-2 text-muted">Find the exact look you're going for.</p>
      </div>
      <a href="/shop" class="hidden shrink-0 text-sm font-semibold text-terracotta transition hover:text-terracotta-dark sm:block">
        Shop all →
      </a>
    </div>
    <div class="grid grid-cols-2 gap-4 sm:gap-5 lg:grid-cols-4">
      {categories.map((c) => (
        <a
          href={`/${c.slug}`}
          class="group relative block overflow-hidden rounded-2xl shadow-soft ring-1 ring-black/5 transition duration-300 hover:-translate-y-1 hover:shadow-lift"
        >
          <img
            src={c.image}
            alt={c.name}
            width="400"
            height="400"
            loading="lazy"
            class="aspect-square w-full object-cover transition duration-500 group-hover:scale-[1.05]"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/10 to-transparent"></div>
          <div class="absolute inset-x-0 bottom-0 p-4">
            <p class="font-serif text-lg font-semibold text-white">{c.name}</p>
            <p class="text-xs text-white/75">{c.count} {c.count === 1 ? 'find' : 'finds'} →</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- TRENDING GRID -->
  <section id="trending" class="scroll-mt-20 bg-white/50">
    <div class="mx-auto max-w-content px-4 py-14">
      <div class="mb-8 text-center">
        <h2 class="font-serif text-3xl font-bold text-ink">Trending now</h2>
        <p class="mt-2 text-muted">Our latest finds, fresh from the bestseller lists.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {trending.map((p, i) => <ProductCard product={p} eager={i < 3} />)}
      </div>
      <div class="mt-10 text-center">
        <a
          href="/shop"
          class="inline-flex items-center justify-center rounded-full bg-ink px-8 py-3.5 text-sm font-semibold text-white shadow-soft transition hover:bg-terracotta"
        >
          Shop all {products.length} finds →
        </a>
      </div>
    </div>
  </section>

  <!-- LATEST BLOG TEASER -->
  {latest && (
    <section class="mx-auto max-w-content px-4 py-14">
      <a
        href={`/blog/${latest.slug}`}
        class="group flex flex-col overflow-hidden rounded-3xl bg-white shadow-soft ring-1 ring-black/5 transition duration-300 hover:shadow-lift md:flex-row"
      >
        {latest.data.cover && (
          <img
            src={latest.data.cover}
            alt={latest.data.title}
            width="640"
            height="480"
            loading="lazy"
            class="aspect-[4/3] w-full object-cover md:w-2/5"
          />
        )}
        <div class="flex flex-1 flex-col justify-center p-6 sm:p-8">
          <span class="text-xs font-semibold uppercase tracking-wide text-terracotta">
            Latest from the blog · {fmt(latest.data.date)}
          </span>
          <h2 class="mt-2 font-serif text-2xl font-bold leading-snug text-ink group-hover:underline">
            {latest.data.title}
          </h2>
          <p class="mt-2 text-muted">{latest.data.description}</p>
          <span class="mt-4 text-sm font-semibold text-terracotta transition group-hover:text-terracotta-dark">
            Read the edit →
          </span>
        </div>
      </a>
    </section>
  )}

  <!-- NEWSLETTER -->
  <Newsletter />
</Layout>
