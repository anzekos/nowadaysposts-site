---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import products from '../data/products.json';
import { SITE } from '../site.config.mjs';

// kategorije + števec (čez vse produkte)
const catMap = new Map();
for (const p of products) {
  const c = catMap.get(p.categorySlug) ?? { slug: p.categorySlug, name: p.category, count: 0 };
  c.count++;
  catMap.set(p.categorySlug, c);
}
const categories = [...catMap.values()].sort((a, b) => a.name.localeCompare(b.name));

// "Trending now" = najnovejših 12 (po addedAt)
const trending = [...products]
  .sort((a, b) => String(b.addedAt ?? '').localeCompare(String(a.addedAt ?? '')))
  .slice(0, 12);

// zadnji blog post (teaser)
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const latest = posts[0];
const fmt = (d) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-gradient-to-b from-cream to-beige/60">
    <div class="mx-auto max-w-content px-4 py-20 text-center sm:py-28">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-terracotta">
        Handpicked home decor, daily
      </p>
      <h1 class="mx-auto max-w-3xl font-serif text-4xl font-bold leading-tight text-ink sm:text-5xl">
        The trending pieces that make a room look designed.
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-muted">
        Mirrors, curtains, rugs and cozy finds we'd actually put in our own home —
        curated fresh every day from thousands of top-rated Amazon bestsellers.
      </p>
      <a
        href="#trending"
        class="mt-8 inline-flex items-center justify-center rounded-full bg-ink px-7 py-3 text-sm font-semibold text-white transition hover:bg-terracotta"
      >
        Shop the trending edit ↓
      </a>
      <p class="mt-4 text-xs text-muted">{SITE.disclosureShort}</p>
    </div>
  </section>

  <!-- KATEGORIJE -->
  <section class="mx-auto max-w-content px-4 py-10">
    <div class="flex flex-wrap justify-center gap-3">
      {categories.map((c) => (
        <a
          href={`/${c.slug}`}
          class="rounded-full border border-ink/15 bg-white px-5 py-2 text-sm font-medium text-ink transition hover:border-terracotta hover:text-terracotta"
        >
          {c.name} <span class="text-muted">({c.count})</span>
        </a>
      ))}
    </div>
  </section>

  <!-- LATEST BLOG TEASER -->
  {latest && (
    <section class="mx-auto max-w-content px-4 py-6">
      <a
        href={`/blog/${latest.slug}`}
        class="group flex flex-col overflow-hidden rounded-3xl bg-white shadow-sm ring-1 ring-black/5 transition hover:shadow-lg md:flex-row"
      >
        {latest.data.cover && (
          <img
            src={latest.data.cover}
            alt={latest.data.title}
            width="640"
            height="480"
            class="aspect-[4/3] w-full object-cover md:w-2/5"
          />
        )}
        <div class="flex flex-1 flex-col justify-center p-6 sm:p-8">
          <span class="text-xs font-semibold uppercase tracking-wide text-terracotta">
            Latest from the blog · {fmt(latest.data.date)}
          </span>
          <h2 class="mt-2 font-serif text-2xl font-bold leading-snug text-ink group-hover:underline">
            {latest.data.title}
          </h2>
          <p class="mt-2 text-muted">{latest.data.description}</p>
          <span class="mt-4 text-sm font-semibold text-ink group-hover:text-terracotta">
            Read the edit →
          </span>
        </div>
      </a>
    </section>
  )}

  <!-- TRENDING GRID -->
  <section id="trending" class="mx-auto max-w-content px-4 pb-6 pt-8">
    <div class="mb-8 text-center">
      <h2 class="font-serif text-3xl font-bold text-ink">Trending now</h2>
      <p class="mt-2 text-muted">Our latest finds, fresh from the bestseller lists.</p>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {trending.map((p) => <ProductCard product={p} />)}
    </div>
  </section>
</Layout>
