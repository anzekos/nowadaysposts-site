---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../site.config.mjs';
---

<Layout title={`Privacy Policy — ${SITE.name}`} description="How this site handles data and cookies.">
  <section class="mx-auto max-w-2xl px-4 py-16">
    <h1 class="font-serif text-4xl font-bold text-ink">Privacy Policy</h1>
    <div class="mt-6 space-y-5 leading-relaxed text-muted">
      <p>
        {SITE.name} is a static informational website. We do not ask for, collect, or store
        personal information such as your name, email or payment details. We have no accounts
        and no contact forms that store data.
      </p>
      <p>
        <strong class="text-ink">Affiliate links &amp; cookies:</strong> When you click an
        Amazon link on this site, Amazon may set cookies to attribute any resulting purchase
        to us so we can earn a commission. The handling of that data is governed by
        <a href="https://www.amazon.com/gp/help/customer/display.html?nodeId=468496" rel="nofollow noopener" target="_blank" class="text-terracotta underline">Amazon's Privacy Notice</a>,
        not ours.
      </p>
      <p>
        <strong class="text-ink">Analytics:</strong> If we add privacy-friendly analytics in
        the future, we'll update this page. We do not sell any data.
      </p>
      <p>
        Questions? Reach out via the channel listed on our
        <a href="/about" class="text-terracotta underline">About</a> page.
      </p>
    </div>
  </section>
</Layout>
